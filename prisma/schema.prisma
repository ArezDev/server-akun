datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL") // <--- Balikno iki, ben engine-ne gak protes "missing"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Pastikan baris iki ono
  role      String   @default("member")
  canUpload Int      @default(0)
  canGet    Int      @default(0)
  created_at DateTime @default(now())
  
  akunFb    FbAkun[]

  @@map("users")
}

model FbAkun {
  id         Int      @id @default(autoincrement())
  fbne       String   // Id user sing upload
  cokis      String   @db.Text // Tipe data TEXT nggo nyimpen cookie sing dowo
  created_at DateTime @default(now())

  // Relasi neng model User (opsional, sesuekno karo foreign key-mu yen ono)
  user       User?    @relation(fields: [fbne], references: [username])

  @@map("fb_akun") // Iki jeneng tabel asli neng MySQL-mu
}